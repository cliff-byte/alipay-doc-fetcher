{
  "name": "alipay-doc-fetcher",
  "version": "0.3.0",
  "description": "把 JS 渲染的支付宝开放平台文档（opendocs/opendoc）抓取为对编程 Agent 友好的 Markdown（含代码块、参数层级、表格、图片）。",
  "keywords": [
    "alipay",
    "支付宝",
    "opendocs",
    "documentation",
    "scraper",
    "playwright",
    "agent-skill",
    "skill",
    "markdown",
    "claude-code",
    "codex",
    "cursor"
  ],
  "homepage": "https://github.com/cliff-byte/alipay-doc-fetcher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliff-byte/alipay-doc-fetcher.git"
  },
  "bugs": {
    "url": "https://github.com/cliff-byte/alipay-doc-fetcher/issues"
  },
  "author": "cliff-byte",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "alipay-doc-fetcher": "./scripts/fetch-alipay-docs.cjs"
  },
  "scripts": {
    "fetch": "node scripts/fetch-alipay-docs.cjs",
    "test": "node --test",
    "postinstall": "echo '请执行: npx playwright install chromium'"
  },
  "dependencies": {
    "playwright": "^1.40.0"
  }
}
